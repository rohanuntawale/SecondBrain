# Copy this file to .env and fill in values.
# cp .env.example .env   (PowerShell: copy .env.example .env)

# Which LLM backend to use: "ollama" (local, offline) or "groq" (free hosted API)
# Default is groq (cloud) so no local model download is needed.
LLM_PROVIDER=groq

# --- Ollama (local dev) ---
# Install from https://ollama.com, then: ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b

# --- Groq (deployed / friend access) ---
# Free key from https://console.groq.com  (no card needed)
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

# --- Paths & retrieval knobs (defaults are fine) ---
NOTES_DIR=notes
CHROMA_DIR=.chroma
EMBED_MODEL=all-MiniLM-L6-v2
TOP_K=4
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_CHARS=150

# --- Advanced retrieval (all free). Light ones default ON; heavy ones default
# OFF so the low-RAM cloud deploy keeps working. Flip to 1 to enable. ---
# Hybrid dense+BM25 keyword search (light, recommended ON):
HYBRID_SEARCH=1
HYBRID_ALPHA=0.6
# Cross-encoder reranking (loads an ~80MB model — turn on locally for best quality):
RERANK=0
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATES=20
# HyDE query expansion (one extra LLM call per query):
HYDE=0
# Contextual retrieval — LLM context per chunk at index time (cached):
CONTEXTUAL_RETRIEVAL=0
# Agentic multi-hop retrieval (lets the model issue follow-up searches):
AGENTIC_RAG=0
AGENTIC_MAX_STEPS=2
# Semantic photo search via CLIP (loads a separate model):
PHOTO_SEARCH=0
CLIP_MODEL=clip-ViT-B-32
# Lightweight JSONL retrieval logging (free observability):
RETRIEVAL_LOG=0
RETRIEVAL_LOG_PATH=logs/retrieval.jsonl

# --- Storage backend ---
# "local"    : notes are Markdown files on this machine (default; single user).
# "supabase" : notes live in a shared Postgres table so multiple people (e.g.
#              you + your partner) see the SAME vault. See docs/SUPABASE_SETUP.md.
STORAGE_BACKEND=local
SUPABASE_URL=
SUPABASE_KEY=

# --- Vector store ---
# "memory"   : in-RAM NumPy, rebuilt from the vault on boot (default; free).
# "pgvector" : persistent Supabase pgvector — see docs/PGVECTOR_SETUP.md.
VECTOR_BACKEND=memory
