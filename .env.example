# Copy this file to .env and fill in values.
# cp .env.example .env   (PowerShell: copy .env.example .env)

# Which LLM backend to use: "ollama" (local, offline) or "groq" (free hosted API)
# Default is groq (cloud) so no local model download is needed.
LLM_PROVIDER=groq

# --- Ollama (local dev) ---
# Install from https://ollama.com, then: ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b

# --- Groq (deployed / friend access) ---
# Free key from https://console.groq.com  (no card needed)
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

# --- Paths & retrieval knobs (defaults are fine) ---
NOTES_DIR=notes
CHROMA_DIR=.chroma
EMBED_MODEL=all-MiniLM-L6-v2
TOP_K=4
CHUNK_MAX_CHARS=1200

# --- Storage backend ---
# "local"    : notes are Markdown files on this machine (default; single user).
# "supabase" : notes live in a shared Postgres table so multiple people (e.g.
#              you + your partner) see the SAME vault. See docs/SUPABASE_SETUP.md.
STORAGE_BACKEND=local
SUPABASE_URL=
SUPABASE_KEY=
